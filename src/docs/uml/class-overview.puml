CrmDbContext --> Product
CrmDbContext --> Deal
CrmDbContext --> DealItem
CrmDbContext --> Activity
CrmDbContext --> TaskItem
CrmDbContext --> SalesForecast
CrmDbContext --> Recommendation

ActivityConfiguration --> Activity
ClientConfiguration --> Client
DealConfiguration --> Deal
DealItemConfiguration --> DealItem
ProductConfiguration --> Product
RecommendationConfiguration --> Recommendation
RoleConfiguration --> Role
SalesForecastConfiguration --> SalesForecast
TaskItemConfiguration --> TaskItem
UserConfiguration --> User
RoleSeeder --> CrmDbContext

MachineLearningOrchestrator --> IForecastModelService
MachineLearningOrchestrator --> IForecastTrainingDataService
MachineLearningOrchestrator --> IRecommendationEngineService
MachineLearningOrchestrator --> CrmDbContext

ForecastTrainingDataService ..|> IForecastTrainingDataService
ForecastModelService ..|> IForecastModelService
RecommendationTrainingDataService ..|> IRecommendationTrainingDataService
RecommendationModelService ..|> IRecommendationModelService
HeuristicRecommendationScorer ..|> IHeuristicRecommendationScorer
